{
  "name": "bakeflow-erp",
  "version": "1.0.0",
  "description": "BakeFlow ERP — Bakery Management System",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest-cli/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest-cli/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest-cli/bin/jest.js --coverage",
    "lint": "eslint js/**/*.js",
    "server": "cd server && node server.js",
    "server:dev": "cd server && pnpm dlx nodemon server.js",
    "install:server": "cd server && pnpm install"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "^(\\.{1,2}/.+)\\.js$": "$1"
    },
    "transform": {},
    "testMatch": ["**/js/__tests__/**/*.test.js"],
    "setupFiles": ["./js/__tests__/setup-globals.js"],
    "setupFilesAfterEnv": ["./js/__tests__/setup.js"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "js/utils.js",
      "js/storage.js"
    ]
  }
}
